{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArclightProtocol",
  "$defs": {
    "ArcCommand": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "v": {
              "type": "number",
              "const": 1
            },
            "commandId": {
              "type": "string",
              "minLength": 1
            },
            "k": {
              "type": "string",
              "const": "submit"
            },
            "sessionId": {
              "type": "string",
              "minLength": 1
            },
            "input": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string",
                  "minLength": 1
                },
                "agent": {
                  "type": "string",
                  "const": "code"
                },
                "mode": {
                  "type": "string",
                  "enum": [
                    "chat",
                    "edit",
                    "test"
                  ]
                },
                "baseEpoch": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "text",
                "agent",
                "baseEpoch"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "v",
            "commandId",
            "k",
            "sessionId",
            "input"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "v": {
              "type": "number",
              "const": 1
            },
            "commandId": {
              "type": "string",
              "minLength": 1
            },
            "k": {
              "type": "string",
              "const": "interrupt"
            },
            "turnId": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "enum": [
                "user",
                "abort"
              ]
            }
          },
          "required": [
            "v",
            "commandId",
            "k",
            "turnId",
            "reason"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "v": {
              "type": "number",
              "const": 1
            },
            "commandId": {
              "type": "string",
              "minLength": 1
            },
            "k": {
              "type": "string",
              "const": "approve"
            },
            "askId": {
              "type": "string",
              "minLength": 1
            },
            "decision": {
              "type": "string",
              "enum": [
                "allow",
                "deny"
              ]
            },
            "scope": {
              "type": "string",
              "enum": [
                "once",
                "session"
              ]
            }
          },
          "required": [
            "v",
            "commandId",
            "k",
            "askId",
            "decision"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "v": {
              "type": "number",
              "const": 1
            },
            "commandId": {
              "type": "string",
              "minLength": 1
            },
            "k": {
              "type": "string",
              "const": "declareCap"
            },
            "profile": {
              "type": "object",
              "properties": {
                "v": {
                  "type": "number",
                  "const": 1
                },
                "localSandbox": {
                  "type": "boolean"
                },
                "screenshot": {
                  "type": "string",
                  "enum": [
                    "none",
                    "static",
                    "stream"
                  ]
                },
                "background": {
                  "type": "string",
                  "enum": [
                    "none",
                    "limited",
                    "full"
                  ]
                },
                "fileSystem": {
                  "type": "string",
                  "enum": [
                    "none",
                    "workspace",
                    "full"
                  ]
                },
                "liveSession": {
                  "type": "boolean"
                }
              },
              "required": [
                "v",
                "localSandbox",
                "screenshot",
                "background",
                "fileSystem",
                "liveSession"
