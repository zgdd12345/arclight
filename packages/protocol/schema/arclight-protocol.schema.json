              "additionalProperties": false
            }
          },
          "required": [
            "v",
            "commandId",
            "k",
            "profile"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "v": {
              "type": "number",
              "const": 1
            },
            "commandId": {
              "type": "string",
              "minLength": 1
            },
            "k": {
              "type": "string",
              "const": "resume"
            },
            "sessionId": {
              "type": "string",
              "minLength": 1
            },
            "afterSeq": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "epoch": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "v",
            "commandId",
            "k",
            "sessionId",
            "afterSeq",
            "epoch"
          ],
          "additionalProperties": false
