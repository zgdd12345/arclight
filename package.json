{
  "name": "arclight",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:core": "bun --hot packages/core/src/serve.ts --repo .",
    "test": "vitest run",
    "test:core": "bun test packages/core tests",
    "check": "biome check . && bun run check:py",
    "check:py": "cd packages/core-py && conda run -n arclight ruff check . && conda run -n arclight python -m pytest -q",
    "check:contract": "cd packages/protocol && bun run emit-schema && cd ../core-py && conda run -n arclight python scripts/gen_models.py && git diff --exit-code -- src/arclight_core/protocol/models.py ../protocol/schema",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=packages/core/drizzle.config.ts",
    "db:migrate": "bun packages/core/src/db/migrate.ts",
    "smoke": "bun scripts/smoke-test-native.ts",
    "eval": "bun evals/runner/run.ts",
    "eval:mock": "ARCLIGHT_EVAL_MOCK=1 bun evals/runner/run.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
